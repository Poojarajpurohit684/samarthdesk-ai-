{
  "$schema": "https://railway.com",
  "services": {
    "frontend-service": {
      "source": {
        "rootDirectory": "frontend"
      },
      "build": {
        "builder": "NIXPACKS"
      },
      "deploy": {
        "startCommand": "npm run build && vite preview --port $PORT --host 0.0.0.0",
        "healthcheckPath": "/"
      }
    },
    "backend-service": {
      "source": {
        "rootDirectory": "backend"
      },
      "build": {
        "builder": "DOCKER"
      },
      "deploy": {
        "healthcheckPath": null
      }
    }
  }
}
